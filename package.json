    "electron:build:mac": "npm run electron:prepare && electron-builder --mac",
    "electron:build:win": "npm run electron:prepare && electron-builder --win",
    "electron:build:linux": "npm run electron:prepare && electron-builder --linux",
    "electron:publish": "npm run electron:prepare && electron-builder --publish always"
