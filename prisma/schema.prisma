datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Scan {
  id          String      @id @default(cuid())
  keyword     String
  createdAt   DateTime    @default(now())
  status      String      @default("PENDING") // PENDING, RUNNING, COMPLETED, FAILED
  centerLat   Float
  centerLng   Float
  radius      Float
  gridSize    Int         @default(3) // e.g., 3x3, 5x5
  shape       String      @default("SQUARE") // SQUARE, CIRCLE, ZIP
  customPoints String?     // Optional JSON string of manual coordinates
  frequency   String      @default("ONCE") // ONCE, DAILY, WEEKLY
  nextRun     DateTime?
  businessName String?     // Name of business to track ranking for (optional)
  placeId     String?     // Google Place ID for accurate tracking
  currentRunId String?    // ID of the current/latest run (for timeline grouping)
  results     Result[]

  @@index([status])
  @@index([createdAt])
  @@index([nextRun])
}

model Result {
  id           String   @id @default(cuid())
  scanId       String
  scan         Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)
  runId        String?  // Groups results by scan execution (null for legacy results)
  runAt        DateTime @default(now())  // When this run started
  lat          Float
  lng          Float
  rank         Int?     // Rank of the target business (null if not found)
  targetName   String?  // Target business name to track
  placeId      String?  // Google Place ID of the result (found business)
  cid          String?  // Google CID of the result
  topResults   String   // List of top 20 businesses found at this point (JSON string)
  capturedAt   DateTime @default(now())

  @@index([scanId])
  @@index([scanId, runId])
}

model Proxy {
  id           String   @id @default(cuid())
  host         String
  port         Int
  username     String?
  password     String?
  type         String   @default("RESIDENTIAL") // RESIDENTIAL, DATACENTER
  enabled      Boolean  @default(true)
  status       String   @default("UNTESTED") // UNTESTED, ACTIVE, DEAD
  lastTestedAt DateTime?
  createdAt    DateTime @default(now())

  @@unique([host, port])
}

model Alert {
  id        String   @id @default(cuid())
  type      String   // RANK_UP, RANK_DOWN, SCAN_ERROR
  message   String
  scanId    String
  createdAt DateTime @default(now())
  read      Boolean  @default(false)

  @@index([read])
  @@index([scanId])
}

model GlobalSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model SystemLog {
  id        String   @id @default(cuid())
  level     String   @default("INFO") // INFO, WARN, ERROR, DEBUG
  message   String
  source    String?  // e.g., "SCANNER", "PROXY_FETCHER", "API"
  details   String?  // JSON string for extra data
  createdAt DateTime @default(now())
}

model Webhook {
  id        String   @id @default(cuid())
  url       String
  events    String   // JSON array: ["SCAN_COMPLETE","RANK_CHANGE","SCAN_FAILED"]
  secret    String?  // Optional HMAC-SHA256 signing secret
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([enabled])
}

model ReviewAnalysis {
  id            String   @id @default(cuid())
  businessName  String
  businessUrl   String
  placeId       String?
  totalReviews  Int      @default(0)
  averageRating Float    @default(0)
  analysisData  String?  // Full JSON blob of 100+ metrics
  status        String   @default("PENDING") // PENDING, SCRAPING, ANALYZING, COMPLETED, FAILED
  error         String?
  currentRunId  String?  // ID of the current/latest run (for history)
  createdAt     DateTime @default(now())
  reviews       Review[]

  @@index([status])
  @@index([createdAt])
}

model Review {
  id              String   @id @default(cuid())
  analysisId      String
  analysis        ReviewAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  runId           String?  // Groups reviews by analysis run (null for legacy)
  runAt           DateTime @default(now()) // When this run was executed
  reviewerName    String
  reviewerUrl     String?
  reviewImage     String?
  reviewCount     Int?
  photoCount      Int?
  rating          Int
  text            String?
  publishedDate   String?
  responseText    String?
  responseDate    String?
  sentimentScore  Float?
  sentimentLabel  String?
  isLikelyFake    Boolean  @default(false)
  fakeScore       Float?
  analysisBlob    String?

  @@index([analysisId])
  @@index([analysisId, runId])
}
